# Firebase Environment Configuration
# Set these using: firebase functions:config:set stripe.secret_key="sk_test_..." etc.

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# SendGrid Configuration
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@eventhub.app

# Security
QR_HMAC_SECRET=your-random-32-char-secret-here

# Firebase Project
FIREBASE_PROJECT_ID=eventhub-app
